# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
*.tmp
*.pid

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

# editor / local tooling artifacts
.claude/
.codex/
.cursor/
.windsurf/
.idea/
.vscode/
claude-outputs/
codex-outputs/
prompt-logs/
transcripts/
tmp/
temp/
test-results/
playwright-report/

# design workflow artifacts that should not be reintroduced to the public repo
design-system/chats/
design-system/**/SKILL.md

# generated native folders
/ios

# android/ is kept under version control so dev builds work without an EAS roundtrip.
# To regenerate: npx expo prebuild --clean
# Per-build artifacts inside it are still ignored:
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
android/app/release/
android/keystores/release.keystore
