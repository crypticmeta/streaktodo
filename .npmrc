# npm configuration for this project, picked up by both local installs
# and EAS Build's install-dependencies phase.
#
# `legacy-peer-deps=true` mirrors the local install workflow we've been using
# throughout development: a transitive react-dom peer-dep conflict (introduced
# by react-native-svg / mixpanel-react-native pulling slightly different React
# peers) blocks a clean `npm install` under npm 7+'s strict resolver, so we
# fall back to npm 6's looser behaviour. EAS Build's default `npm install`
# would otherwise fail in the install phase.
legacy-peer-deps=true
