# Web client ID from Google Cloud Console.
# Used as the audience for the idToken — your Next.js backend verifies against this.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# iOS-only. Reversed iOS client ID (com.googleusercontent.apps.<id>), NOT the app scheme.
# Required before iOS builds. Leave blank for Android-only dev (a placeholder is used).
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
